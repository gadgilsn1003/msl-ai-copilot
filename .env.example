# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (optional, alternative LLM)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# NCBI/PubMed API Key (free at https://www.ncbi.nlm.nih.gov/account/)
NCBI_API_KEY=your-ncbi-api-key-here
NCBI_EMAIL=your-email@example.com

# Supabase (for persistent storage - free tier available)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# App Settings
APP_ENV=development
MAX_ARTICLES_PER_SEARCH=20
DEFAULT_THERAPEUTIC_AREA=oncology
